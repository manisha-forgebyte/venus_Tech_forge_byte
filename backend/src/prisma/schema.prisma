model Filing {
  id        String   @id @default(cuid())
  fid       Int      @unique @default(autoincrement())
  cid       Int      @default(1)
  uid       Int?
  status    String?
  isActive  Boolean  @default(true)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cid])
}


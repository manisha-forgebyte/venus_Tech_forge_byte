model OperatingReserve {
  id        String   @id @default(cuid())
  pid       Int      @unique @default(autoincrement())
  cid       Int
  gid       Int      @default(1)
  isActive  Boolean  @default(true)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cid])
}

model Invoice {
  id        String   @id @default(cuid())
  invoiceId Int      @unique @default(autoincrement())
  cid       Int
  aid       Int      @default(1)
  agid      Int?
  isSent    Boolean  @default(false)
  isBilled  Boolean  @default(false)
  isPaid    Boolean  @default(false)
  isActive  Boolean  @default(true)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cid])
  @@index([aid])
}

model MonthlyInvoice {
  id        String   @id @default(cuid())
  invoiceId Int      @unique @default(autoincrement())
  cid       Int
  aid       Int      @default(1)
  agid      Int?
  isSent    Boolean  @default(false)
  isBilled  Boolean  @default(false)
  isPaid    Boolean  @default(false)
  isActive  Boolean  @default(true)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cid])
  @@index([aid])
}

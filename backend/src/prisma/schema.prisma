  id        String   @id @default(cuid())
  pid       Int      @unique @default(autoincrement())
  cid       Int
  gid       Int      @default(1)
  isActive  Boolean  @default(true)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cid])
}

model ImssParameter {
  id        String   @id @default(cuid())
  pid       Int      @unique @default(autoincrement())
  imssId    Int
  cid       Int
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cid])
  @@index([imssId])
